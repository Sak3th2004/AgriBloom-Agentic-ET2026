# AgriBloom Agentic - Environment Configuration Template
# Copy this to .env and fill in your API keys

# Google Gemini API (FREE - get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Model paths
AGRIBLOOM_VISION_MODEL_DIR=models/checkpoints/efficientnet_b4_indian

# Offline mode default (true/false)
AGRIBLOOM_OFFLINE_DEFAULT=false
